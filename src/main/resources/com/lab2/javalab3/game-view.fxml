<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="620.0" prefWidth="930.0"
            style="-fx-background-color: #f3f7fb;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.lab2.javalab3.client.GameClientController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="14.0" right="14.0" bottom="10.0" left="14.0" />
            </padding>
            <children>
                <HBox spacing="18.0">
                    <children>
                        <Label fx:id="shotsCounter" prefWidth="170.0" text="Shots: 0">
                            <font>
                                <Font name="Segoe UI Semibold" size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="scoreCounter" prefWidth="260.0" text="Score: 0">
                            <font>
                                <Font name="Segoe UI Semibold" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Label fx:id="statusLabel" prefWidth="870.0" text="Waiting for connection...">
                    <font>
                        <Font name="Segoe UI" size="13.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </top>
    <center>
        <Canvas fx:id="mainCanvas" focusTraversable="true" height="490.0" width="650.0" BorderPane.alignment="CENTER" />
    </center>
    <right>
        <VBox spacing="10.0" prefWidth="250.0" BorderPane.alignment="TOP_LEFT">
            <padding>
                <Insets top="14.0" right="14.0" bottom="14.0" left="8.0" />
            </padding>
            <children>
                <Label text="Players">
                    <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                    </font>
                </Label>
                <TextArea fx:id="playersArea" editable="false" focusTraversable="false" prefHeight="490.0"
                          prefWidth="228.0" wrapText="false" />
            </children>
        </VBox>
    </right>
    <bottom>
        <ButtonBar prefHeight="60.0" prefWidth="930.0" BorderPane.alignment="CENTER">
            <buttons>
                <Button fx:id="readyButton" focusTraversable="false" mnemonicParsing="false" onAction="#handleReady"
                        prefHeight="28.0" prefWidth="150.0" text="Ready" textFill="#2853a6">
                    <font>
                        <Font name="Segoe UI Semibold" size="12.0" />
                    </font>
                </Button>
                <Button fx:id="pauseButton" focusTraversable="false" mnemonicParsing="false" onAction="#handlePause"
                        prefHeight="28.0" prefWidth="150.0" text="Pause" textFill="#2853a6">
                    <font>
                        <Font name="Segoe UI Semibold" size="12.0" />
                    </font>
                </Button>
                <Button fx:id="shootButton" focusTraversable="false" mnemonicParsing="false" onAction="#handleShoot"
                        prefHeight="28.0" prefWidth="150.0" text="Shoot (Space)" textFill="#2853a6">
                    <font>
                        <Font name="Segoe UI Semibold" size="12.0" />
                    </font>
                </Button>
                <Button fx:id="leaderboardButton" focusTraversable="false" mnemonicParsing="false"
                        onAction="#handleLeaderboard" prefHeight="28.0" prefWidth="150.0"
                        text="Leaderboard" textFill="#2853a6">
                    <font>
                        <Font name="Segoe UI Semibold" size="12.0" />
                    </font>
                </Button>
            </buttons>
        </ButtonBar>
    </bottom>
</BorderPane>
